@page "/access-denied"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center gap-4" Style="height: 80vh;">
    
    <MudIcon Icon="@Icons.Material.Filled.GppMaybe" Color="Color.Error" Style="font-size: 6rem;" />
    
    <MudText Typo="Typo.h4" Align="Align.Center">Access Denied</MudText>
    
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-4">
        You don't have the required permissions to view this page.
        If you believe this is an error, please check your login credentials.
    </MudText>
    
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.ArrowBack">
        Return to Dashboard
    </MudButton>

</MudContainer>