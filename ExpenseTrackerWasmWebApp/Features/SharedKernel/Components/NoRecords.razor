<MudStack Spacing="1" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="mt-10">
    @if (Filtered)
    {
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Surface" />
    }
    else
    {
        <MudIcon Icon="@Icons.Material.Filled.PostAdd" Size="Size.Large" Color="Color.Surface" />
    }
    <MudText Typo="Typo.h5" Class="mt-4">@Title</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">@Message</MudText>
</MudStack>

@code {
    [Parameter]
    public string Title { get; set; } = null!;

    [Parameter]
    public string Message { get; set; } = null!;

    [Parameter]
    public bool Filtered { get; set; }
}
