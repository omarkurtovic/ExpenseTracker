@page "/transactions"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using ExpenseTrackerSharedCL.Features.Categories.Dtos
@using ExpenseTrackerSharedCL.Features.SharedKernel
@using ExpenseTrackerSharedCL.Features.SharedKernel.Services
@using ExpenseTrackerSharedCL.Features.Tags.Dtos
@using ExpenseTrackerSharedCL.Features.Transactions.Dtos
@using ExpenseTrackerSharedCL.Features.Transactions.Services
@using ExpenseTrackerWasmWebApp.Features.Transactions.Enums
@using ExpenseTrackerWasmWebApp.Features.Transactions.Services
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components.Titles
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components.Dialogs
@using System.Net.Http.Headers
@using ExpenseTrackerWasmWebApp.Features.DataSeeding.Components
@using MudBlazor.Extensions
@using ExpenseTrackerWasmWebApp.Features.Export.Components
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject ITransactionService TransactionService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(IsReoccuring ? "Reoccuring Transactions" : "Transactions")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="d-flex flex-column gap-5 mt-6">

    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MainPageTitle Title="@(IsReoccuring ? "Reoccuring Transactions" : "Transactions")"></MainPageTitle>
        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
            <MudBadge Content="@Filters.ActiveFilterCount" Color="Color.Primary" Overlap="true" Visible="@Filters.AreAnyFiltersActive">
                <MudIconButton Icon="@Icons.Material.Filled.FilterList"
                               Color="Color.Default"
                               OnClick="OpenFilters" />
            </MudBadge>
            <MudButton Class="d-none d-md-flex" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenEditor(null))" StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
            <FabButton Class="d-flex d-md-none" Text="Add" IconClass="@Icons.Material.Filled.Add" OnClick="@(() => OpenEditor(null))" />
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="false">
                <MudMenuItem Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshPage">Refresh</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Download" OnClick="OpenExport">Export CSV</MudMenuItem>
                <AuthorizeView>
                    <Authorized>
                        @if (context.User.IsInRole("Administrator") || context.User.Identity?.Name == "sa")
                        {
                            <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="OpenSeed">
                                Seed Test Data
                            </MudMenuItem>
                        }
                    </Authorized>
                </AuthorizeView>
            </MudMenu>
        </MudStack>
    </MudStack>

    @if (Filters.AreAnyFiltersActive)
    {
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap">
            <MudText Typo="Typo.body2" Class="mr-2">Active Filters:</MudText>
            
            @if (Filters.AccountsFilter.Any())
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.AccountsFilter = [])">
                    @(Filters.AccountsFilter.Count() == 1 ? $"Account: {Filters.AccountsFilter.First().Name}" : $"Accounts ({Filters.AccountsFilter.Count()})")
                </MudChip>
            }
            
            @if (Filters.CategoriesFilter.Any())
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.CategoriesFilter = [])">
                    @(Filters.CategoriesFilter.Count() == 1 ? $"Category: {Filters.CategoriesFilter.First().Name}" : $"Accounts ({Filters.CategoriesFilter.Count()})")
                </MudChip>
            }
            
            @if (Filters.CategoriesFilter.Any())
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.CategoriesFilter = [])">
                    @(Filters.CategoriesFilter.Count() == 1 ? $"Category: {Filters.CategoriesFilter.First().Name}" : $"Category ({Filters.CategoriesFilter.Count()})")
                </MudChip>
            }

            @if (Filters.DateFilter != null)
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.DateFilter = null)">
                    @($"Date: {Filters.DateFilter.ToString()}")
                </MudChip>
            }
            
            @if (Filters.TypeFilter != null)
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.TypeFilter = null)">
                    @($"Type: {Filters.TypeFilter.ToString()}")
                </MudChip>
            }
            
            @if (Filters.TagsFilter.Any())
            {
                <MudChip T="string" Variant="Variant.Filled" OnClose="@(() => Filters.TagsFilter = [])">
                    @(Filters.TagsFilter.Count() == 1 ? $"Tags: {Filters.TagsFilter.First().Name}" : $"Tags ({Filters.TagsFilter.Count()})")
                </MudChip>
            }
            
            <MudButton Color="Color.Default"
            Variant="Variant.Outlined" Size="Size.Small" OnClick="Filters.ClearFilters">Clear All</MudButton>
        </MudStack>
    }

    <MudDataGrid @ref="@DataGrid" T="TransactionDto" Hover Groupable Height="65vh" ItemSize="30f"
                 SortMode="SortMode.Single" ServerData="ServerReload" FixedHeader FixedFooter>
        <NoRecordsContent>
            @if (Filters.AreAnyFiltersActive)
            {
                <NoRecords Title="No transactions found"
                           Message="Change your filters or search terms to show transactions." Filtered />
            }
            else
            {
                <NoRecords Title="No transactions yet"
                           Message="Create your first transaction to start tracking your spending." />
            }
        </NoRecordsContent>
        <Columns>
            <PropertyColumn Property="t => t.AccountDto!.Name" Title="Account" Sortable="true" Groupable="false">
                <CellTemplate>
                    <TextWithIcon Text="@context.Item.AccountDto!.Name"
                                  Icon="@context.Item.AccountDto.Icon" IconColor="@context.Item.AccountDto.Color" IconSize="Size.Small"></TextWithIcon>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="t => t.CategoryDto!.Name" Title="Category" Sortable="true" Groupable="false">
                <CellTemplate>
                    <TextWithIcon Text="@context.Item.CategoryDto!.Name"
                                  Icon="@context.Item.CategoryDto.Icon"
                                  IconColor="@context.Item.CategoryDto.Color" IconSize="Size.Small"></TextWithIcon>
                </CellTemplate>
            </PropertyColumn>
            @if (IsReoccuring)
            {
                <PropertyColumn Sortable="true" Property="t => t.NextReoccuranceDate"
                                Title="Next reoccurance" Format="dd/MM/yyyy"></PropertyColumn>
            }
            else
            {
                <PropertyColumn Property="t => t.DateStr" Title="Time" Grouping="true" GroupExpanded="true"
                                Sortable="true" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
                    <GroupTemplate>
                        @if (@context.Grouping.Key!.ToString() == DateTime.Now.ToString("yyyy-MM-dd"))
                        {
                            <span>Today</span>
                        }
                        else if (@context.Grouping.Key!.ToString() ==
                    DateTime.Now.AddDays(-1).ToString("yyyy-MM-dd"))
                        {
                            <span>Yesterday</span>
                        }
                        else
                        {
                            <span>@(context.Grouping.Key)</span>
                        }
                    </GroupTemplate>
                    <CellTemplate>
                        @context.Item.Date!.Value.TimeOfDay.ToString(@"hh\:mm")
                    </CellTemplate>
                </PropertyColumn>
            }
            <PropertyColumn Property="t => t.Amount" Title="Amount" Sortable="true" Groupable="false">
                <CellTemplate>
                    <AmountDisplay Amount="(decimal)context.Item.Amount!" />
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Tags" Filterable="false" Sortable="false" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell" Groupable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="2" Class="flex-wrap">
                        @foreach (var tag in context.Item.TransactionTags)
                        {
                            <MudChip T="TagDto"
                                     Size="Size.Small"
                                     Style="@($"background-color:{tag.Tag.Color}; color:{ColorService.GetContrastText(tag.Tag.Color)};")">
                                @tag.Tag.Name
                            </MudChip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn>
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="false">
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditor(context.Item))">
                            Edit
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => ConfirmDelete((int)context.Item.Id!))">
                            <MudText Color="Color.Error">Delete</MudText>
                        </MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="TransactionDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

<MudDrawer @bind-Open="@IsSideDrawerOpen" 
           Fixed="true"
           Anchor="Anchor.End"
           Variant="@DrawerVariant.Temporary"
           Width="min(100vw, 400px)"
           Elevation="2">
    <div class="px-6 mt-6">
        @if (DrawerMode == DrawerMode.Filters)
        {
            <TransactionsFilters Close="CloseDrawerRefresh" Filters="@Filters"></TransactionsFilters>
        }
        else if (DrawerMode == DrawerMode.AddTransaction)
        {
            <TransactionEditor Close="CloseDrawer" @ref="TransactionDialog" OnTransactionSaved="CloseDrawerRefresh" IsReoccuring="@IsReoccuring" />
        }
        else if (DrawerMode == DrawerMode.Export)
        {
            <Export Close="CloseDrawer" Options="ExportOptions" OnExportFinished="CloseDrawer" />
        }
        else if (DrawerMode == DrawerMode.Seeding)
        {
            <DataSeed Close="CloseDrawer" OnSeedingFinished="CloseDrawerRefresh" />
        }
    </div>
</MudDrawer>
@code {

    [Parameter]
    [SupplyParameterFromQuery(Name = "isreoccuring")]

    public bool IsReoccuring { get; set; } = false;

    private MudDataGrid<TransactionDto> DataGrid = null!;

    private int NumberOfTransactions = -1;

    private SortDefinition<TransactionDto>? CurrentSort;

    private TransactionEditor TransactionDialog = null!;

    private TransactionsFiltersDto Filters { get; set; } = new TransactionsFiltersDto();

    private bool IsSideDrawerOpen = false;

    private DrawerMode DrawerMode;

    private void CloseDrawer() => IsSideDrawerOpen = false;

    private void OpenDrawer(DrawerMode mode)
    {
        IsSideDrawerOpen = true;
        DrawerMode = mode;
    }
    
    private void OpenEditor(TransactionDto? transactionDto)
    {
        TransactionDialog.SetupTransaction(transactionDto);
        OpenDrawer(DrawerMode.AddTransaction);
    }

    private void OpenFilters() => OpenDrawer(DrawerMode.Filters);

    private void OpenSeed() => OpenDrawer(DrawerMode.Seeding);

    private void OpenExport() => OpenDrawer(DrawerMode.Export);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await DataGrid.ReloadServerData();
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task<GridData<TransactionDto>> ServerReload(GridState<TransactionDto> state)
    {
        TransactionsGridOptionsDto options = new TransactionsGridOptionsDto();
        options.IsReoccuring = IsReoccuring;
        var sortDefintion = state.SortDefinitions.FirstOrDefault();
        if (sortDefintion != null)
        {
            options.SortBy = sortDefintion.SortBy;
            options.SortDescending = sortDefintion.Descending;
            CurrentSort = sortDefintion;
        }
        options.PageSize = state.PageSize;
        options.CurrentPage = state.Page;
        options.Filters = Filters;
        var result = await TransactionService.GetTransactionsAsync(options);

        if (result.IsSuccess && result.Data is not null)
        {
            return new GridData<TransactionDto>()
            {
                Items = result.Data.Transactions,
                TotalItems = result.Data.TotalItems
            };
        }

        if (result.Reason == FailureReason.Unauthorized)
        {
            Snackbar.Add("Session expired. Please log in again.", Severity.Error);
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? "Error fetching transactions!", Severity.Error);
        }

        return new GridData<TransactionDto>()
        {
            Items = new List<TransactionDto>(),
            TotalItems = 0
        };
    }

    private async Task ConfirmDelete(int transactionId)
    {
        var parameters = new DialogParameters<ConfirmDeleteDialog>
        {
            { x => x.Message, "Are you sure you want to delete this transaction?" },
            { x => x.OnDelete, () => TransactionService.DeleteTransactionAsync(transactionId) }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("Confirm", parameters);
        var dialogResult = await dialog.Result;

        if (!dialogResult!.Canceled)
        {
            var apiResult = (Result)dialogResult.Data!;
        
            if (apiResult.IsSuccess)
            {
                Snackbar.Add("Transaction successfully deleted!", Severity.Success);
                await RefreshPage();
            }
            else
            {
                Snackbar.Add(apiResult.ErrorMessage ?? "Error deleting transaction!", Severity.Error);
            }
        }
    }

    private TransactionsGridOptionsDto ExportOptions
    {
        get
        {
            var options = new TransactionsGridOptionsDto();
            options.Filters = Filters;
            options.IsReoccuring = IsReoccuring;
            options.PageSize = int.MaxValue;
            options.CurrentPage = 0;

            if (CurrentSort != null)
            {
                options.SortBy = CurrentSort.SortBy;
                options.SortDescending = CurrentSort.Descending;
            }
            return options;
        }    
    }

    private async Task CloseDrawerRefresh()
    {
        CloseDrawer();
        await RefreshPage();
    }
    

    private async Task RefreshPage()
    {
        if (DataGrid != null)
        {
            await DataGrid.ReloadServerData();
        }
        else
        {
            StateHasChanged();
        }
    }
}