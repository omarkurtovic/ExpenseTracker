@page "/categories"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using ExpenseTrackerSharedCL.Features.Categories
@using ExpenseTrackerSharedCL.Features.Categories.Dtos
@using ExpenseTrackerSharedCL.Features.SharedKernel
@using ExpenseTrackerWasmWebApp.Features.Categories.Services
@using ExpenseTrackerWasmWebApp.Features.SharedKernel
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components.Dialogs
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components.Titles
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICategoryService CategoryService
@inject NavigationManager NavigationManager

<PageTitle>Categories</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex flex-column gap-5 mt-6">
    
    <MudGrid>
        <MudItem xs="12">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MainPageTitle Title="Categories"></MainPageTitle>
                <MudButton Class="d-none d-md-flex" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenEditor(null))" StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
                <FabButton Class="d-flex d-md-none" Text="Add" IconClass="@Icons.Material.Filled.Add" OnClick="@(() => OpenEditor(null))" />
            </MudStack>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="searchString"
                          Placeholder="Search categories..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSelect T="TransactionTypeDto?" @bind-Value="transactionType" Variant="Variant.Outlined">
                <MudSelectItem Value="TransactionTypeDto.Expense">Expenses</MudSelectItem>
                <MudSelectItem Value="TransactionTypeDto.Income">Incomes</MudSelectItem>
            </MudSelect>
        </MudItem>

        @if (AllCategories == null)
        {
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="40%" Height="20px" />
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <div style="display: grid; grid-template-rows: repeat(2, min-content); grid-template-columns: 120px 1fr; gap:1rem; align-items: center; justify-content: center;">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="100px" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="50%" Height="32px" />

                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="90px" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="40%" Height="32px" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
        else if (AllCategories.Count == 0)
        {
            <MudItem xs="12">
                <NoRecords Title="No categories created yet"
                           Message="Create your first category to start organizing your transactions."
                           Icon="@Icons.Material.Filled.Category"></NoRecords>
            </MudItem>
        }
        else if (FilteredCategories == null || FilteredCategories.Count == 0)
        {
            <MudItem xs="12">
                <NoRecords Title="No categories found"
                           Message="Change your search terms to show categories."
                           Icon="@Icons.Material.Filled.SearchOff"></NoRecords>
            </MudItem>
        }
        else
        {
            @if (IsRefreshing)
            {
                <MudItem xs="12">
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                </MudItem>
            }
            @foreach (var category in FilteredCategories)
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudIcon Icon="@category.Icon" Size="Size.Large" Style="@($"color:{category.Color};")"></MudIcon>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.caption">@category.Name</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="false">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditor(category))">
                                        Edit
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => ConfirmDelete((int)category.Id!))">
                                        <MudText Color="Color.Error">Delete</MudText>
                                    </MudMenuItem>
                                </MudMenu>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <div style="display: grid; grid-template-rows: repeat(2, min-content); grid-template-columns: 120px 1fr; gap:1rem; align-items: center; justify-content: center;">
                            
                                <MudText Typo="Typo.body1">@(category.Type == TransactionTypeDto.Income ? "Total income: " : "Total expenses: ")</MudText>
                                <AmountDisplay Amount="@category.TotalAmount" FontSize="Typo.h5" />

                                <MudText Typo="Typo.body1" Class="flex-grow-1">vs Last Month:</MudText>
                                <MudText Typo="Typo.h5" Color="@category.ComparisonColor" Class="month-comparison">
                                    @category.ComparisonDisplay
                                </MudText>
                            
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>



</MudContainer>

<MudDrawer @bind-Open="@_isSideDrawerOpen"
           Fixed="true"
           Anchor="Anchor.End"
           Variant="@DrawerVariant.Temporary"
           Width="min(100vw, 400px)"
           Elevation="2">

    <div class="px-6 mt-6">
        <CategoryEditor Close="CloseDrawer" OnCategorySaved="CloseDrawerRefresh" CategoryDto="@CategoryToEdit" />
    </div>


</MudDrawer>

@code {
    public List<CategoryWithStatsDto> AllCategories { get; set; } = null;

    private bool _isSideDrawerOpen = false;

    private void CloseDrawer() => _isSideDrawerOpen = false;

    private CategoryDto CategoryToEdit = new CategoryDto();

    public string searchString = "";

    public TransactionTypeDto? transactionType = TransactionTypeDto.Expense;

    public List<CategoryWithStatsDto> FilteredCategories
    {
        get
        {
            return AllCategories
            .Where(c => (string.IsNullOrWhiteSpace(searchString) || c.Name!.Contains(searchString, StringComparison.OrdinalIgnoreCase)) && (transactionType == null || c.Type == transactionType))
            .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshPage();
    }

    private async Task OpenEditor(CategoryWithStatsDto? category)
    {
        var categoryDto = new CategoryDto();
        if (category == null)
        {
            categoryDto.Color = "#1976d2";
            categoryDto.Type = transactionType;
        }
        else
        {
            categoryDto = new CategoryDto
            {
                Id = category.Id,
                Name = category.Name,
                Color = category.Color,
                Icon = category.Icon,
                Type = category.Type
            };
        }

        CategoryToEdit = categoryDto;
        _isSideDrawerOpen = true;
    }

    private async Task CloseDrawerRefresh()
    {
        CloseDrawer();
        await RefreshPage();
    }
    
    private async Task ConfirmDelete(int categoryId)
    {
        var parameters = new DialogParameters<ConfirmDeleteDialog>
        {
            { x => x.Message, "Are you sure you want to delete the category?" },
            { x => x.OnDelete, () => CategoryService.DeleteCategoryAsync(categoryId) }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("Confirm", parameters);
        var dialogResult = await dialog.Result;

        if (!dialogResult!.Canceled)
        {
            var apiResult = (Result)dialogResult.Data!;
        
            if (apiResult.IsSuccess)
            {
                Snackbar.Add("Category successfully deleted!", Severity.Success);
                await RefreshPage();
            }
            else
            {
                Snackbar.Add(apiResult.ErrorMessage ?? "Error deleting category!", Severity.Error);
            }
        }
    }
    
    private bool IsRefreshing = false;

    private async Task RefreshPage()
    {
        IsRefreshing = true;
        StateHasChanged();

        try
        {
            var result = await CategoryService.GetCategoriesWithStatsAsync();
            if (result.IsSuccess)
            {
                AllCategories = result.Data ?? new();
            }
            else if (result.Reason == FailureReason.Unauthorized)
            {
                Snackbar.Add("Session expired. Please log in again.", Severity.Error);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(result.ErrorMessage ?? "Error loading categories!", Severity.Error);
            }
        }
        finally
        {
            IsRefreshing = false;
        }
    }

}
