@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using ExpenseTrackerSharedCL.Features.Categories
@using ExpenseTrackerSharedCL.Features.SharedKernel
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components.Titles
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using ExpenseTrackerSharedCL.Features.Categories.Dtos
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components
@using ExpenseTrackerWasmWebApp.Features.Categories.Services
@using global::ExpenseTrackerWasmWebApp.Features.Categories
@inject ISnackbar Snackbar
@inject ICategoryService CategoryService
@inject NavigationManager NavigationManager

@if (CategoryDto is not null)
{
    <MudForm @ref="form">
        <MudGrid Spacing="2" Class="my-2">
            <MudItem xs="12">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <EditorTitle Title="@(CategoryDto.Id == null ? "Add Category" : "Edit Category")"></EditorTitle>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Default"
                                   OnClick="@(async () => await Close.InvokeAsync())" />
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="CategoryDto.Name" Label="Name" Variant="Variant.Outlined" Required="true"
                                RequiredError="Name is required!">
                </MudTextField>
            </MudItem>
            <MudItem xs="12">
                <MudSelect @bind-Value="CategoryDto.Type" Label="Type" Variant="Variant.Outlined" Required="true"
                            RequiredError="Type is required!">
                    @foreach (TransactionTypeDto? item in Enum.GetValues(typeof(TransactionTypeDto)))
                    {
                        <MudSelectItem Value="@item">@item</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudSelect @bind-Value="CategoryDto.Icon" Label="Icon" Variant="Variant.Outlined" Required="true"
                           RequiredError="Icon is required!" Class="flex-grow-1" Style="width: 100%;" FullWidth="true">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Class="my-2">
                        @foreach (string? item in CategoriesHelper.GetDefaultCategoryIcons())
                        {
                            <MudSelectItem Value="@item" Style="width: 40px; height: 40px; padding: 8px;">
                                <MudIcon Icon="@item" Style="@($"color:{CategoryDto.Color};")" Size="Size.Medium" />
                            </MudSelectItem>
                        }
                    </MudStack>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudColorPicker @bind-Text="CategoryDto.Color" Label="Color" Variant="Variant.Outlined" Required="true"
                                RequiredError="Color is required!">
                </MudColorPicker>
            </MudItem>
        </MudGrid>
    </MudForm>
    <MudStack Row Justify="Justify.Center" AlignItems="AlignItems.Center">
        <LoadingButton OnClick="SaveAsync" Class="mt-4">
            Save Category
        </LoadingButton>
    </MudStack>
}


@code {
    MudForm form = null!;

    [Parameter]
    public CategoryDto CategoryDto { get; set; } = new();

    [Parameter]
    public EventCallback OnCategorySaved { get; set; }

    [Parameter]
    public EventCallback Close { get; set; }

    private async Task SaveAsync()
    {
        await form.Validate();
        if (!form.IsValid)
        {
            StateHasChanged();
            return;
        }
        Result result;
        if(CategoryDto.Id == null)
        {
            result = await CategoryService.CreateCategoryAsync(CategoryDto);
        }
        else{
            result = await CategoryService.EditCategoryAsync(CategoryDto);
        }

        if(result.IsSuccess){
            Snackbar.Add("Category saved successfully!", Severity.Success);
            await OnCategorySaved.InvokeAsync();
        }
        else if(result.Reason == FailureReason.Unauthorized)
        {
            Snackbar.Add("Session expired. Please log in again.", Severity.Error);
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? "Error saving category!", Severity.Error);
        }
    }
}