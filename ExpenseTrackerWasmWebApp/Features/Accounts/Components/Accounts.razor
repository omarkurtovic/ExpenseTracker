@page "/accounts"
@attribute [Authorize]
@rendermode InteractiveWebAssembly

@implements IDisposable
@using ExpenseTrackerSharedCL.Features.Accounts.Dtos
@using ExpenseTrackerSharedCL.Features.Accounts.Services
@using ExpenseTrackerWasmWebApp.Features.Accounts.Services
@using ExpenseTrackerWasmWebApp.Features.SharedKernel
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using ExpenseTrackerWasmWebApp.Features.SharedKernel.Components
@using System.Net.Http.Headers
@using MudBlazor.Utilities
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IAccountService AccountService
@inject NavigationManager NavigationManager
@inject PersistentComponentState ApplicationState


<PageTitle>Accounts</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex flex-column gap-5 mt-6">

    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Accounts</MudText>
        <MudButton Class="d-none d-md-flex" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenAccountDialogAsync(null))" StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
        <FabButton Class="d-flex d-md-none" Text="Add" IconClass="@Icons.Material.Filled.Add" OnClick="@(() => OpenAccountDialogAsync(null))" />
    </MudStack>

    <MudGrid>
        <MudItem xs="12">
            <MudTextField @bind-Value="searchString"
                          Placeholder="Search accounts..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Variant="Variant.Outlined"
                          Immediate="true" />
        </MudItem>
    </MudGrid>
              
    @if (AllAccounts == null || AllAccounts.Count == 0)
    {
        <MudText Typo="Typo.h5">No accounts created yet!</MudText>
    }
    else if (FilteredAccounts == null || FilteredAccounts.Count == 0)
    {
        <MudText Typo="Typo.h5">No accounts found!</MudText>
    }
    else
    {

        <MudGrid>
            @foreach (var account in FilteredAccounts)
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1" >
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudIcon Icon="@account.Icon" Size="Size.Large" Style="@($"color:{account.Color};")"></MudIcon>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@account.Name</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="false">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenAccountDialogAsync(account))">
                                        Edit
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => ConfirmDelete((int)account.Id!))">
                                        <MudText Color="Color.Error">Delete</MudText>
                                    </MudMenuItem>
                                </MudMenu>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Row>
                                <MudText Typo="Typo.body1">Balance: </MudText>
                                <AmountDisplay Amount="@account!.CurrentBalance" FontSize="Typo.body1" />
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {

    public List<AccountWithBalanceDto> AllAccounts { get; set; } = [];

    public List<AccountWithBalanceDto> FilteredAccounts
    {
        get
        {
            return AllAccounts
            .Where(c => (string.IsNullOrWhiteSpace(searchString) || c.Name!.Contains(searchString, StringComparison.OrdinalIgnoreCase)))
            .ToList();
        }
    }
    private string searchString = "";


    private PersistingComponentStateSubscription persistingSubscription;

    protected override async Task OnInitializedAsync()
    {
        if (!ApplicationState.TryTakeFromJson<List<AccountWithBalanceDto>>(nameof(AllAccounts), out var accounts))
        {
            await UpdatePage();
        }
        else
        {
            AllAccounts = accounts!;
        }

        persistingSubscription = ApplicationState.RegisterOnPersisting(PersistAccounts);
    }

    private Task PersistAccounts()
    {
        ApplicationState.PersistAsJson(nameof(AllAccounts), AllAccounts);
        return Task.CompletedTask;
    }
    public void Dispose()
    {
        persistingSubscription.Dispose();
    }

    private async Task OpenAccountDialogAsync(AccountWithBalanceDto? accountWithBalance)
    {
        var accountDto = new AccountDto();
        if (accountWithBalance == null)
        {
            accountDto.Color = "#1976d2";
        }
        else
        {
            accountDto.Id = accountWithBalance.Id;
            accountDto.Name = accountWithBalance.Name;
            accountDto.InitialBalance = accountWithBalance.InitialBalance;
            accountDto.Color = accountWithBalance.Color;
            accountDto.Icon = accountWithBalance.Icon;
        }
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            NoHeader = false,
            CloseButton = true,
            MaxWidth = MaxWidth.Medium
        };

        var parameters = new DialogParameters<AccountDialog>();
        parameters.Add(d => d.AccountDto, accountDto);

        var dialog = await DialogService.ShowAsync<AccountDialog>(title: "", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            await UpdatePage();
        }
    }


    private async Task ConfirmDelete(int accountId)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, "Are you sure you want to delete the account and the related transactions? " }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title: "", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            var res = await AccountService.DeleteAccountAsync(accountId);
            if (res.IsSuccess)
            {
                Snackbar.Add("Account successfully deleted!", Severity.Success);
                await UpdatePage();
            }
            else if (res.Reason == FailureReason.Unauthorized)
            {
                Snackbar.Add("Session expired. Please log in again.", Severity.Error);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(res.ErrorMessage?.ToString() ?? "Error deleting account!", Severity.Error);
            }
        }
    }


    private async Task UpdatePage()
    {
        var result = await AccountService.GetAccountsWithBalanceAsync();
        if (result.IsSuccess)
        {
            AllAccounts = result.Data!;
        }
        else if (result.Reason == FailureReason.Unauthorized)
        {
            Snackbar.Add("Session expired. Please log in again.", Severity.Error);
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.ErrorMessage!, Severity.Error);
            NavigationManager.NavigateTo("/login");
        }
    }
}